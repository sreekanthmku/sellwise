# Copy this file to .env in this same folder (server/.env):
#   cp server/.env.example server/.env

# HTTP port (optional, default 3001)
# PORT=3001

# Public https origin of this API (no trailing slash), e.g. your ngrok URL.
# Used for <Record action> / callbackUrl in outbound call XML.
PUBLIC_BASE_URL=https://your-subdomain.ngrok-free.app

# Your Vobiz phone number (E.164 format).
CALLER_ID=+91XXXXXXXXXX

# SIP Endpoint URI for inbound calls (PSTN -> browser).
SIP_ENDPOINT=sip:myusername@registrar.vobiz.ai

# Optional: download recordings from Vobiz-hosted media URLs
# RECORDING_X_AUTH_ID=
# RECORDING_X_AUTH_TOKEN=

# --- Post-recording LLM analysis (audio) ---
# LLM_PROVIDER: gemini | openai | none (none = skip analysis)
LLM_PROVIDER=none

# Gemini (when LLM_PROVIDER=gemini)
# GEMINI_API_KEY=
# GEMINI_MODEL=gemini-2.0-flash

# OpenAI — not implemented yet; reserved for LLM_PROVIDER=openai
# OPENAI_API_KEY=
# OPENAI_MODEL=gpt-4o
#
# Fetch analysis (polls ./call-analysis/<id>.json every 3s, same id as recording-callback file):
#   GET /api/call-analysis/<call_uuid>?maxAttempts=100
